# Copy this file to ".env" and fill in your key.

# --- Image generation provider ---
# Which provider to use: "openai" (default), "stability", or "mock"
IMAGE_PROVIDER=openai

# OpenAI (default). Uses the gpt-image-1 model.
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Stability AI (optional alternative). Set IMAGE_PROVIDER=stability to use.
# Get a key: https://platform.stability.ai/account/keys
STABILITY_API_KEY=

# Server port
PORT=3000
